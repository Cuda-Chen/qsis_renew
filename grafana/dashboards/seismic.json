{
  "title": "Phidget Seismic Dashboard",
  "uid": "seismic_main",
  "schemaVersion": 38,
  "editable": false,
  "time": {
    "from": "now-1m",
    "to": "now"
  },
  "panels": [
    {
      "title": "Clean Seismic Waveform",
      "type": "timeseries",
      "datasource": {
        "type": "grafana-mqtt-datasource",
        "uid": "mqtt_local"
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "targets": [
        { "refId": "A", "topic": "telemetry/seismic" }
      ],
      "transformations": [
        { "id": "extractFields", "options": { "format": "json", "replace": false, "source": "A" } },
        { "id": "organize", "options": { "excludeByName": { "A": true, "status": true, "timestamp": true } } }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "axisCenteredZero": true,
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "lineWidth": 2,
            "spanNulls": false
          },
          "min": -2,
          "max": 2
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "title": "Frequency Spectrogram",
      "type": "heatmap",
      "datasource": {
        "type": "grafana-mqtt-datasource",
        "uid": "mqtt_local"
      },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 10 },
      "targets": [
        { "refId": "A", "topic": "telemetry/spectrogram" }
      ],
      "transformations": [
        { "id": "extractFields", "options": { "format": "json", "replace": false, "source": "A" } },
        { "id": "organize", "options": { "excludeByName": { "A": true, "status": true, "timestamp": true } } },
        { "id": "prepareTimeSeries", "options": { "format": "multi-frame time series" } }
      ],
      "options": {
        "calculate": false,
        "color": {
          "fill": "solid",
          "mode": "scheme",
          "scheme": "Spectral",
          "steps": 128
        },
        "legend": { "show": true },
        "yAxis": { "axisPlacement": "left", "reverse": false }
      }
    }
  ]
}
